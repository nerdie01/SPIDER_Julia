   "source": [
    "include(\"mhd_ieuler.jl\")\n",
    "using .MHD_FDM, Random\n",
    "\n",
    "N::Int64 = 64\n",
    "steps::Int = 150\n",
    "dt = 2^-7\n",
    "\n",
    "Random.seed!(1)\n",
    "fω(x,y) = randn()\n",
    "\n",
    "Random.seed!(2)\n",
    "fj(x,y) = randn()\n",
    "\n",
    "forcing(x,y) = sin(2x) + sin(2y)\n",
    "\n",
    "ν = 2^-6\n",
    "η = 2^-6\n",
    "\n",
    "MHD_FDM.mhd_fdm(fω, fj, forcing, N, dt, steps, ν, η)"
   ]
  }
